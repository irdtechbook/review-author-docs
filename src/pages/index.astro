---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  authorityGroups,
  featuredRoutes,
  heroImages,
  siteDescription,
  siteTitle
} from "../lib/site-data";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const chapters = (await getCollection("chapters")).sort(
  (left, right) => left.data.order - right.data.order
);
const chapterPath = (id) => `${base}chapters/${id.replace(/\.md$/, "")}/`;
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <section class="hero hero-grid">
    <img
      class="hero-image"
      src={heroImages.home}
      alt="本とノートが並ぶ執筆机"
      loading="eager"
    />
    <div class="shell hero-copy">
      <p class="eyebrow">はじめて書籍化する著者向け</p>
      <h1>はじめてのRe:VIEW<br />技術同人誌商業化ガイド</h1>
      <p class="hero-text">
        はじめて技術同人誌を商業化する著者が、最初の原稿作成から設定、修正、公開確認まで進められるように、
        迷いやすい順でまとめています。
      </p>
      <div class="hero-actions">
        <a class="button-primary" href={chapterPath(chapters[0].id)}>最初の章へ</a>
        <a class="button-secondary" href={`${base}sources/`}>参考資料を見る</a>
      </div>
    </div>
  </section>

  <section class="shell section-spacing route-section">
    <div class="section-heading">
      <p class="eyebrow">最初の一歩</p>
      <h2>最小構成で書き始める</h2>
    </div>
    <div class="card-grid">
      <article class="info-card">
        <h3>1. 章ファイルを 1 つ作る</h3>
        <p>
          まずは短い 1 章だけを書きます。最初から本全体を書こうとせず、見出し、本文、箇条書きが通るかを確かめます。
        </p>
        <a href={chapterPath("00-start-here.md")}>はじめにを見る</a>
      </article>
      <article class="info-card">
        <h3>2. 最小限の設定を書く</h3>
        <p>
          `config.yml` と `catalog.yml` は最小限で十分です。まずは「本の題名」と「どの章を読むか」だけを通します。
        </p>
        <a href={chapterPath("04-config-and-catalog.md")}>設定例を見る</a>
      </article>
      <article class="info-card">
        <h3>3. NG 記法を先に避ける</h3>
        <p>
          Nextpublishing 固有の修正ポイントは、あとでまとめて直すより先に避けたほうが楽です。よくある NG を先に確認できます。
        </p>
        <a href={chapterPath("05-nextpublishing-policy.md")}>NG 記法を見る</a>
      </article>
    </div>
  </section>

  <section class="shell section-spacing route-section">
    <div class="section-heading">
      <p class="eyebrow">3 つの入口</p>
      <h2>いまの目的から入る</h2>
    </div>
    <div class="card-grid">
      {featuredRoutes.map((route) => (
        <article class="info-card">
          <h3>{route.title}</h3>
          <p>{route.description}</p>
          <a href={`${base}chapters/${route.chapterSlug}/`}>この読み順を開く</a>
        </article>
      ))}
    </div>
  </section>

  <section class="shell section-spacing chapter-section">
    <div class="section-heading">
      <p class="eyebrow">章一覧</p>
      <h2>章ごとに読む</h2>
    </div>
    <div class="chapter-list">
      {chapters.map((chapter) => (
        <article class="chapter-card">
          <div class="chapter-order">{String(chapter.data.order + 1).padStart(2, "0")}</div>
          <div>
            <h3>
              <a href={chapterPath(chapter.id)}>{chapter.data.title}</a>
            </h3>
            <p>{chapter.data.summary}</p>
            <ul class="tag-list" aria-label="対象読者">
              {chapter.data.audience.map((audience) => <li>{audience}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="shell section-spacing authority-section">
    <div class="section-heading">
      <p class="eyebrow">説明の根拠</p>
      <h2>どの根拠で説明しているか</h2>
    </div>
    <div class="card-grid">
      {authorityGroups.map((group) => (
        <article class="info-card">
          <h3>{group.title}</h3>
          <p>{group.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
