---
import BaseLayout from "../layouts/BaseLayout.astro";
import { heroImages, sourceGroups } from "../lib/site-data";

const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Sources" description="この docs hub が依拠している source classes と代表 source 一覧。">
  <section class="page-hero">
    <img class="page-hero-image" src={heroImages.sources} alt="開いた本とメモ" />
    <div class="shell page-hero-copy">
      <p class="eyebrow">Source trail</p>
      <h1>このサイトの説明は、何を根拠にしているか。</h1>
      <p>
        公式仕様、author repo の観測、Nextpublishing diagnostics を分けて保持し、説明文では混線しないようにしています。
      </p>
      <a class="button-secondary" href={base}>Home に戻る</a>
    </div>
  </section>

  <section class="shell section-spacing source-groups">
    {sourceGroups.map((group) => (
      <article class="source-card">
        <h2>{group.title}</h2>
        <ul class="source-list">
          {group.items.map((item) => (
            <li>
              {item.href ? <a href={item.href}>{item.label}</a> : <strong>{item.label}</strong>}
              <p>{item.note}</p>
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>
</BaseLayout>
