---
import "../styles/global.css";
import { siteDescription, siteTitle } from "../lib/site-data";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title && title !== siteTitle ? `${title} | ${siteTitle}` : siteTitle;
const pageDescription = description ?? siteDescription;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://images.unsplash.com" />
  </head>
  <body>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href={base}>
          <span class="brand-kicker">Re:VIEW / Nextpublishing</span>
          <strong>{siteTitle}</strong>
        </a>
        <nav class="top-nav" aria-label="Primary">
          <a href={base}>トップ</a>
          <a href={`${base}tag-reference/`}>タグ一覧</a>
          <a href={`${base}sources/`}>参考資料</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <p>{siteTitle} は、はじめて書籍化する著者向けに、公式 Re:VIEW 文書、著者リポジトリ実例、Nextpublishing の診断情報をつなぎ直した解説サイトです。</p>
      </div>
    </footer>
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "loose",
        theme: "base",
        themeVariables: {
          primaryColor: "#fff7f2",
          primaryTextColor: "#14213d",
          primaryBorderColor: "#ff7f50",
          lineColor: "#0f766e",
          secondaryColor: "#edf6f9",
          tertiaryColor: "#fef3c7"
        }
      });

      mermaid.run({ querySelector: ".mermaid" });
    </script>
  </body>
</html>
